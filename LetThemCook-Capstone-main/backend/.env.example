# LetThemCook local Llama/Ollama integration
# true = use Ollama when available, with LetThemCook dataset guardrails
# false = use mock CSV/database fallback only
USE_OLLAMA=true
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=8
OLLAMA_BASE_URL=http://localhost:11434
CHROMA_EMBED_MODEL=all-minilm
CHROMA_COLLECTION=letthemcook_recipes
