# LetThemCook local Llama/Ollama integration
# true = use Ollama when available; false = use the local CSV fallback only.
USE_OLLAMA=true

# Ollama server and chat endpoint.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434/api/chat

# Use the exact model tag shown by: ollama list
# Keep this aligned with the local model used by the capstone.
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=180

# ChromaDB settings for local semantic recipe search.
CHROMA_EMBED_MODEL=all-minilm
CHROMA_COLLECTION=letthemcook_recipes
